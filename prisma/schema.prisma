// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String   @id @default(cuid())
  email         String   @unique
  passwordHash  String
  name          String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // AI Settings
  aiTone             String?  @default("friendly")
  autoReplyEnabled   Boolean? @default(false)
  replyDelay         Int?     @default(30) // minutes
  maxRepliesPerHour  Int?     @default(10)
  businessContext    String?
  notificationEmail  String?

  // Relations
  connections     Connection[]
  monitoredContent MonitoredContent[]
  replySettings   ReplySettings?
  rateLimits      RateLimit?

  @@map("users")
}

model Connection {
  id            String   @id @default(cuid())
  userId        String
  platform      Platform
  accessToken   String   // AES-256 encrypted
  refreshToken  String?  // AES-256 encrypted
  expiresAt     DateTime?
  channelId     String?  // Platform channel/user ID
  channelName   String?  // Platform display name
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Relations
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, platform])
  @@map("connections")
}

model MonitoredContent {
  id                String   @id @default(cuid())
  userId            String
  platform          Platform
  platformContentId String   // Video/post ID from platform
  title             String?  // Content title for display
  isMonitored       Boolean  @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  // Relations
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, platform, platformContentId])
  @@map("monitored_content")
}

model ReplySettings {
  id                String   @id @default(cuid())
  userId            String   @unique
  businessContext   String?  // User's business description for AI context
  minConfidenceScore Float    @default(0.7) // Only auto-reply if AI confidence > 70%
  replyToTypes      String[] // Array of comment types to reply to: ["question", "complaint", "praise"]
  tone              String   @default("professional") // "professional", "friendly", "casual"
  maxReplyLength    Int      @default(500) // Maximum characters for replies
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  // Relations
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("reply_settings")
}

model RateLimit {
  id                String   @id @default(cuid())
  userId            String   @unique
  repliesToday      Int      @default(0)
  repliesThisHour   Int      @default(0)
  lastReset         DateTime @default(now())
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  // Relations
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("rate_limits")
}

enum Platform {
  YOUTUBE
  INSTAGRAM
  FACEBOOK
}
